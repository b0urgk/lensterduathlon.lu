<section class="archive-page">
    <div class="archive-page__inner">
        <h1 class="archive-page__title"><%= content.archiveTitle || 'Archiv' %></h1>

        <% archives.forEach(entry => { %>
            <section class="archive-year" id="archive-<%= entry.year %>">
                <div class="archive-year__header">
                    <h2 class="archive-year__title"><%= entry.year %></h2>
                    <% if (entry.resultsLink) { %>
                        <a class="archive-year__results"
                           href="<%= entry.resultsLink %>"
                           target="_blank" rel="noopener noreferrer">
                            <i class="fa-solid fa-trophy"></i>
                            <span><%= content.archiveResults || ({ en: 'Results', fr: 'Résultats', de: 'Resultate' }[lang] || 'Resultate') %></span>
                        </a>
                    <% } %>
                </div>

                <% if (entry.photos.length > 0) { %>
                    <div class="archive-gallery">
                        <% entry.photos.forEach(photo => { %>
                            <a class="archive-gallery__item"
                               href="<%= photo.fullUrl %>"
                               target="_blank" rel="noopener noreferrer">
                                <img src="<%= photo.thumbUrl %>"
                                     alt="<%= entry.year %> – <%= photo.file %>"
                                     loading="lazy">
                            </a>
                        <% }) %>
                    </div>
                <% } else { %>
                    <p class="archive-year__empty">
                        <%= content.archiveNoPhotos || 'Noch keine Fotos verfügbar.' %>
                    </p>
                <% } %>
            </section>
        <% }) %>
    </div>
</section>
