<section class="sponsors-page">
    <div class="sponsors-page__inner">
        <h1 class="sponsors-page__title"><%= content.sponsorsTitle || 'Sponsors' %></h1>
        <div class="sponsors-grid">
            <% sponsorImages.forEach(function (sponsor){ %>
                <a class="sponsors-grid__item"
                   href="<%= sponsor.url %>"
                   target="_blank" rel="noopener noreferrer">
                    <img src="/public/images/<%= sponsor.file %>" alt="<%= sponsor.file %>" class="sponsor-logo">
                </a>
            <% }) %>
        </div>
    </div>
</section>
